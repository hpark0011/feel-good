{
  "name": "feel-good",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "desktop:dev": "turbo run dev --filter=@feel-good/greyboard-desktop",
    "desktop:build": "turbo run build --filter=@feel-good/greyboard-desktop",
    "desktop:dist": "pnpm --filter @feel-good/greyboard-desktop dist",
    "desktop:lint": "turbo run lint --filter=@feel-good/greyboard-desktop",
    "desktop:check-types": "turbo run check-types --filter=@feel-good/greyboard-desktop"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
   "node": ">=20.9.0"
  }
}